{
  "manifest_version": 3,
  "name": "FitMirror - AI Virtual Try-On",
  "version": "1.0.0",
  "description": "Virtually try on clothes directly from e-commerce pages using AI.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["sidePanel", "activeTab", "storage"],
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.amazon.in/*",
    "*://*.flipkart.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.amazon.in/*",
        "*://*.flipkart.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "Open FitMirror Panel"
  }
}
